APP_NAME=HAPOS
APP_ENV=production
PUBLIC_APP_URL=https://app.example.com
HAPOS_RUNTIME_MODE=auto
HAPOS_COOKIE_SECURE=true

DATABASE_URL=postgresql://user:password@host/database?sslmode=require
POSTGRES_POOL_MAX=20

JWT_SECRET=replace-me
JWT_ISSUER=hapos-api
JWT_AUDIENCE=hapos-web

DEFAULT_TIMEZONE=Africa/Nairobi
DEFAULT_CURRENCY=KES

AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=replace-me
AFRICASTALKING_BASE_URL=https://api.sandbox.africastalking.com
AFRICASTALKING_SENDER_ID=HAPOS

SUPER_ADMIN_BOOTSTRAP_EMAIL=owner@example.com
